.Dd June 26, 2026
.Dt LIBBDE 3
.Os
.Sh NAME
.Nm libbde.h
.Nd Library to access the BitLocker Drive Encryption (BDE) format
.Sh SYNOPSIS
.In libbde.h
.Pp
Support functions
.nf
.Ft const char *
.Fo libbde_get_version
.Fa "void"
.Fc
.fi
.nf
.Ft int
.Fo libbde_get_access_flags_read
.Fa "void"
.Fc
.fi
.nf
.Ft int
.Fo libbde_get_codepage
.Fa "int *codepage"
.Fa "libbde_error_t **error"
.Fc
.fi
.nf
.Ft int
